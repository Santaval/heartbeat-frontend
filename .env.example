# Postgres connection string (Neon / Vercel Postgres in production)
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# Shared admin panel password
ADMIN_PASSWORD="change-me"

# Long random string used to sign the admin session cookie (HMAC)
SESSION_SECRET="generate-a-long-random-string"

# Optional: message rotation interval in ms (default 12h = 43200000)
# ROTATE_INTERVAL_MS=43200000
